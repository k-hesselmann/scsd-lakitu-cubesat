 #define BOARD_DEBUG_UART_TYPE     kSerialPort_Uart
 #define BOARD_DEBUG_UART_CLK_FREQ 24000000
 
-#define BOARD_DEBUG_UART_INSTANCE_M7 6U
-#define BOARD_UART_CLOCK_ROOT_M7     kCLOCK_Root_Lpuart6
+/* Moved off LPUART6 so the header UART6 pins are free for the OBC link
+ * (cloud_payload). Console output still reaches USB CDC; LPUART7's pins
+ * are not routed anywhere on the Dev Board Micro. Must be an instance <= 8:
+ * the serial adapter (fsl_adapter_lpuart.c) only provides IRQ handlers for
+ * LPUART0-8, anything higher hangs in DefaultISR at boot. */
+#define BOARD_DEBUG_UART_INSTANCE_M7 7U
+#define BOARD_UART_CLOCK_ROOT_M7     kCLOCK_Root_Lpuart7
 #define BOARD_DEBUG_UART_BAUDRATE_M7 (115200U)
 
